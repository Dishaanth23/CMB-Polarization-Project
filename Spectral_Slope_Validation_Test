def local_slope_loglog(ell, C, delta_bins=2):
    ell = np.asarray(ell)
    C = np.asarray(C)

    # avoid log of nonpositive values
    C_safe = np.where(C > 0, C, np.nan)

    logell = np.log(ell)
    logC   = np.log(C_safe)

    s = np.full_like(C, np.nan, dtype=float)
    d = int(delta_bins)

    # central difference in log-log space
    s[d:-d] = (logC[d*2:] - logC[:-d*2]) / (logell[d*2:] - logell[:-d*2])
    return s

