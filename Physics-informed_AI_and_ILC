def corrupt(x, noise_std=0.10, drop_prob=0.05, channel_drop_prob=0.10, W=11):
    """
    x: tensor of shape (B, 3*W)
    Adds noise + random feature dropout + optional whole-channel dropout.
    """
    x_noisy = x.clone()


    x_noisy = x_noisy + noise_std * torch.randn_like(x_noisy)

    if drop_prob > 0:
        mask = (torch.rand_like(x_noisy) > drop_prob).float()
        x_noisy = x_noisy * mask


    if channel_drop_prob > 0:
        B, F = x_noisy.shape
        ch = torch.randint(0, 3, (B,), device=x_noisy.device)
        do_drop = (torch.rand(B, device=x_noisy.device) < channel_drop_prob)

        channel_mask = torch.ones_like(x_noisy)
        for i in range(B):
            if do_drop[i]:
                channel_mask[i, ch[i]::3] = 0.0  # zero every 3rd feature starting at ch
        x_noisy = x_noisy * channel_mask

    return x_noisy

class DenoiseAE(nn.Module):
    def __init__(self, in_dim):
        super().__init__()
        self.encoder = nn.Sequential(
            nn.Linear(in_dim, 24),
            nn.ReLU(),
            nn.Linear(24, 8),
            nn.ReLU(),
        )
        self.decoder = nn.Sequential(
            nn.Linear(8, 24),
            nn.ReLU(),
            nn.Linear(24, in_dim),
        )

    def forward(self, x):
        z = self.encoder(x)
        out = self.decoder(z)
        return out

in_dim = X_train.shape[1]
