def ilc_weights(X):
    """
    X: (N, C) matrix of C channels over N ell-bins.
    Returns weights w (C,) minimizing variance with constraint sum(w)=1.
    """

    R = np.cov(X, rowvar=False)


    eps = 1e-12 * np.trace(R) / R.shape[0]
    R = R + eps * np.eye(R.shape[0])


    one = np.ones((R.shape[0], 1))
    Rinv = np.linalg.inv(R)
    numer = Rinv @ one
    denom = (one.T @ Rinv @ one).item()
    w = (numer / denom).flatten()
    return w, R


