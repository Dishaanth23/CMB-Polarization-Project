    n_train = 0

    for (xb,) in train_loader:
        xb = xb.to(device)
        xb_corrupt = corrupt(xb)

        pred = model(xb_corrupt)
        loss = loss_fn(pred, xb)

        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

        train_loss += loss.item() * xb.size(0)
        n_train += xb.size(0)

    train_loss /= n_train

    model.eval()
    val_loss = 0.0
    n_val = 0

    with torch.no_grad():
        for (xb,) in val_loader:
            xb = xb.to(device)
            xb_corrupt = corrupt(xb)  # corruption also on val to measure denoising ability
            pred = model(xb_corrupt)
            loss = loss_fn(pred, xb)

            val_loss += loss.item() * xb.size(0)
            n_val += xb.size(0)

    val_loss /= n_val

    if val_loss < best_val:
        best_val = val_loss
        best_state = {k: v.detach().cpu().clone() for k, v in model.state_dict().items()}

    if epoch == 1 or epoch % 10 == 0:
        print(f"Epoch {epoch:3d} | train_loss={train_loss:.6f} | val_loss={val_loss:.6f} | best_val={best_val:.6f}")

